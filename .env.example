# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/agario_db

# Auth
JWT_SECRET=change-me
ADMIN_USERNAME=your-admin-username

# Solana wallets — main arena (normal Agar/Slither, swept on arena reset)
HOUSE_WALLET_ADDRESS=
HOUSE_WALLET_SECRET=
OWNER_VAULT_ADDRESS=
# Chainstack Solana Mainnet Global Node HTTPS endpoint
SOLANA_RPC_URL=https://solana-mainnet.core.chainstack.com/your-node-access-token

# Battle Royale house wallets — separate pool per variant AND entry fee ($5 / $10)
# NOT swept on arena reset. Generate: node scripts/generate-br-wallets.mjs
BR_AGAR_HOUSE_WALLET_ADDRESS=
BR_AGAR_HOUSE_WALLET_SECRET=
BR_AGAR_10_HOUSE_WALLET_ADDRESS=
BR_AGAR_10_HOUSE_WALLET_SECRET=
BR_SLITHER_HOUSE_WALLET_ADDRESS=
BR_SLITHER_HOUSE_WALLET_SECRET=
BR_SLITHER_10_HOUSE_WALLET_ADDRESS=
BR_SLITHER_10_HOUSE_WALLET_SECRET=

# Reward Pool wallet — separate from house, owner vault, and BR wallets
# Generate: node scripts/generate-reward-wallet.mjs
REWARD_WALLET_ADDRESS=
REWARD_WALLET_SECRET=

# Dev tools — reset arena & sweep house wallet to owner
DEV_RESET_SECRET=change-me-for-local-testing

# Free test play — no real Solana on join/cashout/reset (NEVER enable on production mainnet)
# DEV_FREE_PLAY=true

# Optional: shorten room duration for testing (milliseconds)
# DEV_ROOM_DURATION_MS=300000
